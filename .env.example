VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Email verification codes are sent by the Edge Function "send-verification-email".
# In Supabase: Project Settings → Edge Functions → Secrets:
#   RESEND_API_KEY=re_...        (create at https://resend.com)
#   RESEND_FROM_EMAIL=optional   (e.g. NXT Campus <verify@yourdomain.com>; Resend trial uses onboarding@resend.dev)
# Auth: Dashboard → Authentication → Providers → Email → turn OFF "Confirm email"
#     so sign-up returns a session and users can enter the 6-digit code on /verify-email.
